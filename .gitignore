# ── 依赖 ──────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── 编译产物 ───────────────────────────────────────────────────────────
dist/
frontend/dist/

# ── 环境变量（含 API Key / Bot Token，绝对不提交）────────────────────
.env
.env.local
.env.*.local

# ── 数据库（运行时生成，不纳入版本控制）──────────────────────────────
radar.db
radar.db-shm
radar.db-wal

# ── 日志 ──────────────────────────────────────────────────────────────
*.log
logs/

# ── 系统文件 ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / 编辑器 ───────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── PM2 ───────────────────────────────────────────────────────────────
.pm2/

# ── 临时文件 ───────────────────────────────────────────────────────────
*.tmp
*.bak
*.bak.*
